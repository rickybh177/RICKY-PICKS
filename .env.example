# ============================================================
# Variables de entorno de RICKY·PICKS
# Copia este archivo como ".env" para desarrollo local
# y configura las MISMAS variables en Vercel (Project → Settings → Environment Variables).
# NUNCA subas el archivo .env real a GitHub (ya está en .gitignore).
# ============================================================

# --- Supabase ---
# URL del proyecto (la misma que usa el frontend).
SUPABASE_URL=https://juzfncioexyerhwweaui.supabase.co
# SERVICE ROLE KEY (secreta). Supabase → Project Settings → API → service_role.
# Se usa en el backend para verificar sesiones y otorgar accesos. NO la expongas.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# --- Mercado Pago ---
# Access Token de producción. Mercado Pago → Tus integraciones → Credenciales.
MP_ACCESS_TOKEN=APP_USR-tu_access_token_aqui
# Secreto para validar la firma del webhook (opcional pero recomendado).
# Mercado Pago → Webhooks → "Clave secreta".
MP_WEBHOOK_SECRET=tu_clave_secreta_de_webhook

# --- Sitio ---
# URL pública del sitio en producción (sin diagonal final).
# Se usa para back_urls y notification_url de Mercado Pago.
SITE_URL=https://ricky-picks.vercel.app
